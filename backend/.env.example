# CivicLink Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Session Secret (change this to a random string in production!)
SESSION_SECRET=civiclink-change-this-secret-in-production-xyz123

# OpenAI API Key (for AI-powered issue detection)
# Get yours at: https://platform.openai.com/api-keys
# If not set, the app still works but AI classification is disabled
OPENAI_API_KEY=your-openai-api-key-here

# Frontend URL (for CORS) - set to your Replit URL in production
FRONTEND_URL=https://civic-issue-reporter--shivanallela363.replit.app
